# ============================================================
# Multi-Agent Task Management System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Gemini / Google AI ---
# Your Google AI Studio API key (primary)
GOOGLE_API_KEY=your_google_api_key_here

# Google Cloud project ID (for Vertex AI fallback)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Model Configuration ---
# Comma-separated fallback chain: tries each model in order
# Available: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
MODEL_FALLBACK_CHAIN=gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# --- Google Calendar ---
# Path to OAuth2 credentials JSON (downloaded from Google Cloud Console)
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json
# Path to store the OAuth2 token after first authentication
GOOGLE_CALENDAR_TOKEN_PATH=./token.json

# --- Notion ---
# Internal Integration Token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=your_notion_integration_token
# Target database ID (from the Notion page URL)
NOTION_DATABASE_ID=your_notion_database_id

# --- Database ---
# SQLite (default — change to postgresql+asyncpg://... for production)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# --- Server ---
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# --- Scheduler (Tier 3) ---
# Enable proactive/autonomous features
SCHEDULER_ENABLED=true
# Daily briefing time (24h format, HH:MM)
DAILY_BRIEFING_TIME=08:00
# Weekly review day and time
WEEKLY_REVIEW_DAY=friday
WEEKLY_REVIEW_TIME=18:00
